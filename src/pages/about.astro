---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout title="关于我" description="了解博主的信息和背景">
  <div class="container-narrow">
    <article class="about-page">
      <!-- Hero Section -->
      <header class="about-header">
        <div class="avatar-container">
          <div class="avatar">
            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </div>
        </div>
        
        <h1>关于我</h1>
        <p class="subtitle">开发者 · 写作者 · 终身学习者</p>
      </header>

      <!-- Introduction -->
      <section class="about-section">
        <h2>👋 你好！</h2>
        <p>
          欢迎来到我的个人博客。我是一名热爱技术的开发者，喜欢探索新技术、分享学习心得。
          在这里，你会找到我对编程、设计和生活的思考。
        </p>
        <p>
          我相信技术可以改变世界，也相信持续学习是成长的关键。希望通过这个平台，
          能够与更多志同道合的朋友交流和学习。
        </p>
      </section>

      <!-- Skills -->
      <section class="about-section">
        <h2>💻 技术栈</h2>
        <div class="skills-grid">
          <div class="skill-category">
            <h3>前端开发</h3>
            <div class="skill-tags">
              <span class="skill-tag">Astro</span>
              <span class="skill-tag">React</span>
              <span class="skill-tag">Vue</span>
              <span class="skill-tag">TypeScript</span>
              <span class="skill-tag">CSS/Tailwind</span>
            </div>
          </div>
          
          <div class="skill-category">
            <h3>后端开发</h3>
            <div class="skill-tags">
              <span class="skill-tag">Node.js</span>
              <span class="skill-tag">Python</span>
              <span class="skill-tag">Go</span>
              <span class="skill-tag">PostgreSQL</span>
              <span class="skill-tag">Redis</span>
            </div>
          </div>
          
          <div class="skill-category">
            <h3>工具 & 其他</h3>
            <div class="skill-tags">
              <span class="skill-tag">Git</span>
              <span class="skill-tag">Docker</span>
              <span class="skill-tag">Linux</span>
              <span class="skill-tag">AWS</span>
              <span class="skill-tag">Figma</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Contact -->
      <section class="about-section">
        <h2>📬 联系方式</h2>
        <p>如果你有任何问题或合作意向，欢迎通过以下方式联系我：</p>
        
        <div class="contact-links">
          <a href="https://github.com/yourusername" target="_blank" rel="noopener noreferrer" class="contact-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
            </svg>
            GitHub
          </a>
          
          <a href="https://twitter.com/yourusername" target="_blank" rel="noopener noreferrer" class="contact-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
            </svg>
            Twitter
          </a>
          
          <a href="mailto:your.email@example.com" class="contact-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            Email
          </a>
        </div>
      </section>
    </article>
  </div>
</BlogLayout>

<style>
  .about-page {
    padding: var(--space-8) 0;
  }

  .about-header {
    text-align: center;
    padding: var(--space-12) 0 var(--space-8);
  }

  .avatar-container {
    margin-bottom: var(--space-6);
  }

  .avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 120px;
    height: 120px;
    background: linear-gradient(135deg, var(--color-primary-container), var(--color-tertiary-container));
    border-radius: var(--radius-full);
    color: var(--color-primary);
  }

  .about-header h1 {
    font-size: var(--font-size-4xl);
    margin-bottom: var(--space-2);
  }

  .subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-on-surface-variant);
  }

  .about-section {
    margin-bottom: var(--space-12);
  }

  .about-section h2 {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--color-outline-variant);
  }

  .about-section h3 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-3);
    color: var(--color-on-surface-variant);
  }

  .about-section p {
    color: var(--color-on-surface);
    line-height: var(--line-height-relaxed);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .skills-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .skill-tag {
    background-color: var(--color-surface-container);
    color: var(--color-on-surface);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    transition: all var(--transition-fast);
  }

  .skill-tag:hover {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    transform: translateY(-2px);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  @media (min-width: 640px) {
    .contact-links {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-surface-container);
    border-radius: var(--radius-md);
    color: var(--color-on-surface);
    font-weight: var(--font-weight-medium);
    transition: all var(--transition-fast);
    min-height: 48px;
  }

  .contact-link:hover {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .contact-link svg {
    flex-shrink: 0;
  }
</style>
