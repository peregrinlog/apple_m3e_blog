---
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const allPosts = await Astro.glob('../../content/posts/*.md');
  
  // Extract all unique tags
  const tagMap = new Map<string, typeof allPosts>();
  
  allPosts.forEach((post) => {
    const tags = post.frontmatter.tags || [];
    tags.forEach((tag: string) => {
      if (!tagMap.has(tag)) {
        tagMap.set(tag, []);
      }
      tagMap.get(tag)!.push(post);
    });
  });
  
  return Array.from(tagMap.entries()).map(([tag, posts]) => ({
    params: { tag },
    props: { 
      tag,
      posts: posts.sort((a, b) => {
        const dateA = new Date(a.frontmatter.date || '');
        const dateB = new Date(b.frontmatter.date || '');
        return dateB.getTime() - dateA.getTime();
      })
    },
  }));
}

interface Props {
  tag: string;
  posts: any[];
}

const { tag, posts } = Astro.props;
---

<BlogLayout title={`标签：${tag}`} description={`查看 ${tag} 标签下的所有文章`}>
  <div class="container">
    <header class="tag-header">
      <nav class="breadcrumb">
        <a href="/">首页</a>
        <span class="separator">/</span>
        <a href="/tags">标签</a>
        <span class="separator">/</span>
        <span>{tag}</span>
      </nav>
      
      <h1>
        <span class="tag-badge">{tag}</span>
      </h1>
      <p class="tag-description">
        共有 {posts.length} 篇文章
      </p>
    </header>

    <!-- Posts List -->
    <section class="posts-section">
      <div class="posts-list">
        {posts.map((post) => (
          <article class="post-item card">
            <a href={post.url} class="post-item-link">
              <h2 class="post-title">{post.frontmatter.title}</h2>
              
              {post.frontmatter.description && (
                <p class="post-excerpt">{post.frontmatter.description}</p>
              )}
              
              <div class="post-meta">
                <time datetime={post.frontmatter.date}>
                  {new Date(post.frontmatter.date).toLocaleDateString('zh-CN', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </time>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>
  </div>
</BlogLayout>

<style>
  .tag-header {
    text-align: center;
    padding: var(--space-12) 0 var(--space-8);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-on-surface-variant);
    margin-bottom: var(--space-6);
  }

  .breadcrumb a {
    color: var(--color-primary);
  }

  .separator {
    color: var(--color-outline);
  }

  .tag-badge {
    display: inline-block;
    background: linear-gradient(135deg, var(--color-primary), var(--color-tertiary));
    color: var(--color-on-primary);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
  }

  .tag-description {
    margin-top: var(--space-4);
    color: var(--color-on-surface-variant);
    font-size: var(--font-size-base);
  }

  .posts-section {
    padding: var(--space-8) 0;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 720px;
    margin: 0 auto;
  }

  .post-item {
    transition: all var(--transition-normal);
  }

  .post-item:hover {
    transform: translateX(var(--space-2));
  }

  .post-item-link {
    display: block;
    color: inherit;
  }

  .post-title {
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-2);
    color: var(--color-on-surface);
    transition: color var(--transition-fast);
  }

  .post-item:hover .post-title {
    color: var(--color-primary);
  }

  .post-excerpt {
    color: var(--color-on-surface-variant);
    font-size: var(--font-size-base);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-3);
  }

  .post-meta {
    font-size: var(--font-size-sm);
    color: var(--color-on-surface-variant);
  }
</style>
